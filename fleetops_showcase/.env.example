# Django Security
SECRET_KEY=django-insecure-replace-this-in-production
DEBUG=True
ALLOWED_HOSTS=securityshadow.pythonanywhere.com,localhost,127.0.0.1

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# Static Files
# STATIC_ROOT=/home/your-username/fleetops_showcase/static

# Production Security
CSRF_TRUSTED_ORIGINS=https://securityshadow.pythonanywhere.com
SECURE_SSL_REDIRECT=False
