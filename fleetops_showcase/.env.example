# Django Security
SECRET_KEY=django-insecure-replace-this-in-production
DEBUG=True
ALLOWED_HOSTS=securityshadow.pythonanywhere.com,localhost,127.0.0.1

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# Static Files
# STATIC_ROOT=/home/your-username/fleetops_showcase/static

# Production Security
CSRF_TRUSTED_ORIGINS=https://securityshadow.pythonanywhere.com
SECURE_SSL_REDIRECT=False

# Supabase URL/Key
SUPABASE_URL=https://[PROJECT-ID].supabase.co
SUPABASE_KEY=[YOUR-ANON-KEY]

# Supabase Storage (S3 Compatible)
AWS_ACCESS_KEY_ID=[YOUR-ACCESS-KEY-ID]
AWS_SECRET_ACCESS_KEY=[YOUR-SECRET-ACCESS-KEY]
AWS_STORAGE_BUCKET_NAME=storage
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=https://[PROJECT-ID].supabase.co/storage/v1/s3
AWS_S3_CUSTOM_DOMAIN=[PROJECT-ID].supabase.co/storage/v1/object/public/storage
